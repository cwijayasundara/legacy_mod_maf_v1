# Copy this file to `.env` and fill in your values.
# Loaded by run_migration.py (repo root) and by the orchestrator subprocess.

# ──────────────────────────────────────────────────────────────────
# Auth — provide EXACTLY ONE of these
# ──────────────────────────────────────────────────────────────────

# Option A: OpenAI directly (local dev)
OPENAI_API_KEY=sk-...

# Option B: Azure AI Foundry (production) — alternative to OPENAI_API_KEY
# FOUNDRY_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com

# ──────────────────────────────────────────────────────────────────
# Model selection
# ──────────────────────────────────────────────────────────────────
# Default OpenAI model used by every agent role. Per-role overrides
# (analyzer/coder/tester/reviewer/...) live in
# ms-agent-harness/config/settings.yaml under `models:`.
OPENAI_MODEL=gpt-4o

# ──────────────────────────────────────────────────────────────────
# Migration source & target (read by run_migration.py)
# Relative paths resolve against the repo root.
# ──────────────────────────────────────────────────────────────────

# AWS Lambda source tree to migrate
SOURCE_DIR=aws_legacy/generated_code

# Output package where generated Azure Functions are written
MIGRATED_DIR=azure_fn

# Logical id for this discovery/migration run
# (used for discovery artifact paths: discovery/<REPO_ID>/*.json)
REPO_ID=legacy-aws

# Port for the spawned orchestrator
ORCHESTRATOR_PORT=8000

# ──────────────────────────────────────────────────────────────────
# Optional observability / operator knobs (see ms-agent-harness README)
# ──────────────────────────────────────────────────────────────────
# LOG_FORMAT=json                  # or `text`
# MAX_CONCURRENT_MIGRATIONS=3

# Keep ms-agent-harness/migration.db across runs (default: delete for a clean run).
# Set to 1 only for incremental reruns where you want discovery/analyzer caching.
# KEEP_DB=1
