{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Migration Sprint Contract",
  "description": "Machine-readable done-criteria negotiated between coder and reviewer before implementation begins. Immutable after finalization.",
  "type": "object",
  "required": ["module", "language", "work_item_id", "proposed_by", "finalized_by", "contract"],
  "properties": {
    "module": { "type": "string" },
    "language": { "enum": ["java", "python", "node", "csharp"] },
    "work_item_id": { "type": "string" },
    "proposed_by": { "const": "migration-coder" },
    "finalized_by": { "const": "migration-reviewer" },
    "created_at": { "type": "string", "format": "date-time" },
    "finalized_at": { "type": "string", "format": "date-time" },
    "contract": {
      "type": "object",
      "required": ["unit_checks", "integration_checks", "contract_checks", "architecture_checks"],
      "properties": {
        "unit_checks": {
          "type": "array",
          "description": "Unit tests that must pass. Each defines a specific behavior to verify.",
          "items": {
            "type": "object",
            "required": ["id", "description", "function_under_test", "expected_behavior"],
            "properties": {
              "id": { "type": "string", "pattern": "^unit-\\d{3}$" },
              "description": { "type": "string" },
              "function_under_test": { "type": "string" },
              "expected_behavior": { "type": "string" },
              "edge_cases": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "integration_checks": {
          "type": "array",
          "description": "Integration tests using Azure emulators (Azurite, Cosmos emulator).",
          "items": {
            "type": "object",
            "required": ["id", "description", "azure_service", "operation"],
            "properties": {
              "id": { "type": "string", "pattern": "^integ-\\d{3}$" },
              "description": { "type": "string" },
              "azure_service": { "type": "string" },
              "operation": { "type": "string" },
              "expected_result": { "type": "string" }
            }
          }
        },
        "contract_checks": {
          "type": "array",
          "description": "API contract checks: request/response schemas must match original Lambda.",
          "items": {
            "type": "object",
            "required": ["id", "method", "path", "expected_status"],
            "properties": {
              "id": { "type": "string", "pattern": "^api-\\d{3}$" },
              "method": { "enum": ["GET", "POST", "PUT", "DELETE", "PATCH"] },
              "path": { "type": "string" },
              "request_body": { "type": "object" },
              "expected_status": { "type": "integer" },
              "expected_body_schema": { "type": "object" },
              "description": { "type": "string" }
            }
          }
        },
        "architecture_checks": {
          "type": "object",
          "description": "Structural requirements for the migrated module.",
          "properties": {
            "files_required": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Files that must exist in the migrated module."
            },
            "no_aws_imports": {
              "type": "boolean",
              "description": "Must be true. Zero AWS SDK imports allowed."
            },
            "bicep_template": {
              "type": "boolean",
              "description": "Infrastructure-as-code template must exist."
            },
            "coverage_minimum": {
              "type": "number",
              "minimum": 80,
              "description": "Minimum line coverage percentage."
            }
          }
        }
      }
    }
  }
}
