{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Structured Failure Report",
  "description": "Machine-readable failure report with error classification for targeted self-healing. Written by tester, consumed by coder.",
  "type": "object",
  "required": ["module", "attempt", "timestamp", "failures"],
  "properties": {
    "module": { "type": "string" },
    "attempt": { "type": "integer", "minimum": 1, "maximum": 3 },
    "timestamp": { "type": "string", "format": "date-time" },
    "overall_verdict": { "enum": ["PASS", "FAIL", "PARTIAL"] },
    "failures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["failure_id", "layer", "error_category", "description"],
        "properties": {
          "failure_id": { "type": "string", "pattern": "^F\\d{3}$" },
          "layer": {
            "enum": ["unit", "integration", "contract"],
            "description": "Which evaluation layer failed."
          },
          "error_category": {
            "enum": [
              "import_error",
              "sdk_mismatch",
              "schema_mismatch",
              "missing_handler",
              "auth_failure",
              "connection_error",
              "timeout",
              "assertion_error",
              "configuration_error",
              "runtime_error"
            ],
            "description": "One of 10 classified error categories for targeted self-healing."
          },
          "description": { "type": "string" },
          "file": { "type": "string", "description": "File where the error originates." },
          "line": { "type": "integer", "description": "Line number if available." },
          "stack_trace": { "type": "string", "description": "Extracted stack trace." },
          "expected": { "type": "string" },
          "actual": { "type": "string" },
          "self_healing_strategy": {
            "type": "string",
            "description": "Recommended fix strategy for this error category."
          }
        }
      }
    },
    "prior_attempts": {
      "type": "array",
      "description": "Summary of what was tried in previous attempts (prevents repeating the same fix).",
      "items": {
        "type": "object",
        "properties": {
          "attempt": { "type": "integer" },
          "strategy": { "type": "string" },
          "result": { "type": "string" }
        }
      }
    }
  }
}
